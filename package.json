{
  "name": "nuxt-quick",
  "version": "1.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">= 20.12.2"
  },
  "scripts": {
    "dev": "nuxt dev --dotenv .env.development",
    "build": "nuxt build --dotenv .env.development",
    "build:prod": "nuxt build --dotenv .env.production",
    "preview": "npm run build && nuxt preview",
    "preview:prod": "npm run build:prod && nuxt preview",
    "generate": "nuxt generate --dotenv .env.generate",
    "lint": "eslint \"./**/*.{js,ts,jsx,tsx,vue}\" && stylelint \"./**/*.{vue,html,css,less,scss,sass}\"",
    "lint:fix": "eslint \"./**/*.{js,ts,jsx,tsx,vue}\" --fix && stylelint \"./**/*.{vue,html,css,less,scss,sass}\" --fix",
    "prepare": "nuxt prepare && husky && husky install"
  },
  "lint-staged": {
    "*.{vue,js,jsx,ts,tsx}": "eslint",
    "*.{vue,css,scss,less,styl,html}": "stylelint"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.cjs"
    }
  },
  "dependencies": {
    "@element-plus/nuxt": "^1.0.10",
    "@nuxt/content": "^2.13.2",
    "@nuxt/image": "^1.8.0",
    "@nuxtjs/color-mode": "^3.4.4",
    "@nuxtjs/google-adsense": "^3.0.0",
    "@nuxtjs/i18n": "^8.5.3",
    "@pinia/nuxt": "^0.5.4",
    "@unocss/reset": "^0.62.3",
    "@vueuse/nuxt": "^11.1.0",
    "element-plus": "^2.8.1",
    "nuxt": "^3.13.1",
    "nuxt-gtag": "^3.0.1",
    "pinia": "^2.2.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.3.2",
    "@iconify/json": "^2.2.246",
    "@nuxt/eslint": "^0.5.6",
    "@nuxtjs/stylelint-module": "^5.2.0",
    "@unocss/eslint-config": "^0.62.3",
    "@unocss/eslint-plugin": "^0.62.3",
    "@unocss/nuxt": "^0.62.3",
    "@unocss/preset-rem-to-px": "^0.62.3",
    "@vueuse/core": "^11.1.0",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.2.1",
    "eslint": "^9.5.0",
    "eslint-plugin-format": "^0.1.2",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.45",
    "postcss-html": "^1.7.0",
    "postcss-scss": "^4.0.9",
    "rehype-autolink-headings": "^7.1.0",
    "remark-heading-id": "^1.0.1",
    "sass": "^1.78.0",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "^6.0.4",
    "typescript": "5.5.4",
    "unocss": "^0.62.3",
    "unplugin-element-plus": "^0.8.0",
    "vite-plugin-eslint2": "^4.4.0",
    "vue-eslint-parser": "^8.0.0",
    "vue-tsc": "2.0.29"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.21.3"
  }
}
